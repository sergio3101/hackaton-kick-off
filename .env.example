# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
# Realtime API (основной голосовой канал). Требует доступа к Realtime у ключа.
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
# Голос: список Realtime API — alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin, cedar.
OPENAI_TTS_VOICE=alloy
# True — голос идёт через Realtime API, False — старый пайплайн (Whisper-batch + TTS-batch).
# При False имеет смысл задать OPENAI_STT_MODEL=whisper-1 и OPENAI_TTS_MODEL=tts-1 (есть defaults в config.py).
VOICE_REALTIME_ENABLED=True

# Postgres
POSTGRES_USER=kickoff
POSTGRES_PASSWORD=kickoff
POSTGRES_DB=kickoff
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
JWT_SECRET=change-me-in-production-please
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:4173
LOG_LEVEL=INFO

# Frontend (build-time)
VITE_API_BASE_URL=http://localhost:8000
